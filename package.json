{
  "name": "vutto-bike-auction-assignment",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "start": "npm --workspace apps/api run start",
    "build": "npm --workspaces run build",
    "render:build:api": "npm ci && npm --workspace apps/api run build:postgres",
    "render:start:api": "npm --workspace apps/api run start:render",
    "test": "npm --workspace apps/api test",
    "db:migrate": "npm --workspace apps/api run db:migrate",
    "db:seed": "npm --workspace apps/api run db:seed"
  },
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
